# FastAPI
APP_NAME="Inbox Assistant"
APP_ENV="local"
LOG_LEVEL="INFO"

# OpenAI
# If OPENAI_API_KEY is missing/empty the app runs in MOCK mode.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4"
OPENAI_BASE_URL=""

# Agent behavior
AGENT_MOCK_MODE="auto"  # auto|on|off

# Gmail API (draft-first)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/oauth/callback"
GOOGLE_REFRESH_TOKEN=""
GOOGLE_ACCESS_TOKEN=""  # optional; typically leave empty when using refresh token
GMAIL_USER_EMAIL="me"
